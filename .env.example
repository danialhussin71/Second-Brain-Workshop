# Jarvis uses the OpenAI API directly. Add this in Vercel environment variables.
OPENAI_API_KEY=
# Optional model override. The default is GPT-5.6 Sol with medium reasoning.
# OPENAI_MODEL=gpt-5.6-sol
# Optional image model override. Carousel artwork defaults to GPT Image 2.
# OPENAI_IMAGE_MODEL=gpt-image-2

# Vercel injects this automatically when Blob is connected to the project.
# BLOB_READ_WRITE_TOKEN=
